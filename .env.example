# ---- Telegram (primary transport for this fork) ----
# 1. Create a bot: @BotFather → /newbot → paste the token below.
# 2. Send any message to your bot, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Find "chat":{"id":<NUMBER>} — that's your chat id.
# 3. Run `npm run dev`. No tunnel or ngrok needed — bot uses long polling.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids. Without this, anyone can message the bot.
TELEGRAM_ALLOWED_CHAT_IDS=

# ---- OpenAI (Whisper voice transcription) ----
# Required for voice message support. Get a key at https://platform.openai.com/api-keys.
# Also doubles as the embedding provider if you set it (see below).
OPENAI_API_KEY=

# ---- Convex ----
# Run: npx convex dev — Convex creates a project and writes these to .env.local automatically.
CONVEX_DEPLOYMENT=
CONVEX_URL=
VITE_CONVEX_URL=

# ---- Claude model ----
# Uses your Claude Code subscription automatically — no separate API key needed.
# Override with ANTHROPIC_API_KEY if you want to bypass the subscription.
#
# BOOP_MODEL controls model selection per turn:
#   - `auto` (default behavior when unset)  → use the per-turn model router
#                                              in server/model-router.ts
#                                              (haiku for chit-chat, sonnet
#                                              for normal turns, opus for
#                                              hard / long-skill turns)
#   - any model id (e.g. claude-sonnet-4-6) → pin every turn to that model
#                                              (legacy behavior; predictable
#                                              cost, no routing)
BOOP_MODEL=auto
# ANTHROPIC_API_KEY=

# ---- Cost guards ----
# Soft cap on bot spend over the trailing 24h. Once total cost (summed from
# usageRecords across dispatcher, execution, extract, and consolidation)
# meets or exceeds this number, the bot starts refusing new model calls
# and tells the user the cap was hit. Rolls off automatically as old
# entries age out of the 24h window. Default: 50 USD if unset.
#
# This is the *internal* tripwire for runaway-bot scenarios (bad cron,
# stuck retry, sub-agent loop). For runaway-key scenarios (leaked
# ANTHROPIC_API_KEY / OPENAI_API_KEY) set hard spend limits in the
# Anthropic Console and OpenAI billing dashboards too — this guard
# can't see API usage that bypasses our usageRecords logging.
# DAILY_COST_USD_CAP=50

# Pre-execution confirm gate (#24). Comma-separated list of cost bands
# that should pause and ask the user "yes?" before running. The
# estimator (server/cost-estimator.ts) labels turns as cheap / normal /
# expensive / extra-expensive based on keywords + content score.
#
# Default (unset): expensive,extra-expensive — gate the top two bands.
# Set to extra-expensive to gate only the worst.
# Set to empty to disable confirm prompts entirely.
# CONFIRM_EXPENSIVE_BANDS=expensive,extra-expensive

# Cost-disclosure footer threshold in USD. When a turn's total spend
# (dispatcher + sub-agent spawns + run_skill) crosses this number, the
# bot appends "(turn cost ~$X.XX)" to its reply so the user notices
# when a single ask routes through opus and burns several dollars.
# Below the threshold, replies stay clean. Default $0.50. Set to 0 to
# always show the footer (loud, useful for debugging). Set to a
# negative number to disable disclosure entirely.
# COST_DISCLOSURE_THRESHOLD_USD=0.5

# Threshold above which `create_automation` refuses to schedule without
# explicit confirmation (force=true) from the dispatcher. Default 24 runs
# per 24h means anything tighter than hourly triggers the warning. Useful
# if you want to be even stricter (e.g. 6 — once per 4 hours minimum).
# CRON_WARN_RUNS_PER_DAY=24

# Coalescing window for rapid-fire text messages from the same chat.
# When the user sends "ось ідея" → "у Linear" → "термін завтра" as three
# separate messages within this window, the bot buffers them and runs the
# dispatcher ONCE on the merged text. Default 1500ms. Set to 0 to
# disable coalescing entirely (every message hits the dispatcher
# immediately) — useful for debugging "did the bot see my message?".
# TEXT_DEBOUNCE_MS=1500

# Minimum time between memory-consolidation runs, in ms. Each run does
# 3 model calls (proposer / adversary / judge), so we don't want them
# firing in rapid succession from a pm2 restart-loop or a misconfigured
# automation. Default: 3_600_000 ms (1 hour). With the auto-loop's 24h
# cadence this only matters for manual `/consolidate` calls.
# CONSOLIDATION_MIN_INTERVAL_MS=3600000

# ---- Per-phase model overrides (cost tuning) ----
# Vision describe (Telegram photo / album → text). Defaults to haiku-4-5,
# which is vision-capable and ~5× cheaper than sonnet for image-describe
# work. Override to sonnet/opus if your use case needs OCR-heavy or
# fine-detail descriptions.
# VISION_MODEL_OVERRIDE=claude-haiku-4-5
#
# Memory consolidation phase models. All three default to haiku-4-5 —
# the proposer/adversary/judge pipeline is structured-JSON reasoning
# with no tool use, where haiku is sufficient. Bump judge to sonnet
# if you observe weak rulings on borderline proposals.
# BOOP_PROPOSER_MODEL=claude-haiku-4-5
# BOOP_ADVERSARY_MODEL=claude-haiku-4-5
# BOOP_JUDGE_MODEL=claude-haiku-4-5
#
# Background memory extraction (runs after every dispatcher turn).
# Defaults to haiku-4-5 — extraction is strict-JSON fact pulling with
# no tool use. Skipped entirely when both user message and assistant
# reply are <50 chars (chit-chat gate).
# BOOP_EXTRACT_MODEL=claude-haiku-4-5

# ---- Upgrade notifications ----
# On `npm run dev`, Boop checks your `upstream` remote for new commits and
# prints a banner with the commit count + a reminder to run `/upgrade-boop`.
# Set to `false` to silence the check entirely.
# BOOP_UPSTREAM_CHECK=true

# ---- Embeddings (optional — unlocks vector search for memory recall) ----
# Pick one. If neither is set, recall falls back to substring search.
# VOYAGE_API_KEY=
# OPENAI_API_KEY=  (already covered above for Whisper)

# ---- Server ----
PORT=3456

# Public URL for your server.
# - Leave as http://localhost:3456 if you're only using Telegram (long polling
#   needs no tunnel).
# - Set to a stable public URL only if you also need inbound webhooks
#   (e.g. dormant Sendblue path below).
PUBLIC_URL=http://localhost:3456

# Optional: ngrok RESERVED domain (paid plan). Example: "boop.ngrok.app".
# Telegram doesn't need this; only relevant if you re-enable Sendblue.
# NGROK_DOMAIN=

# ---- Composio (1000+ integrations, zero-code) ----
# Get an API key at https://app.composio.dev/developers.
# Once set, connect toolkits (Gmail, Slack, GitHub, Linear, …) from the
# Debug UI's Connections tab. Each connected toolkit becomes available to
# the agent via spawn_agent(integrations: [...]).
COMPOSIO_API_KEY=

# Optional: stable user id Composio keys connections under. Defaults to
# "boop-default". Override only if you already manage Composio sessions
# elsewhere and want Boop to reuse that user.
# COMPOSIO_USER_ID=

# ============================================================================
# DORMANT — Sendblue / iMessage transport
# ============================================================================
# Sendblue is the upstream's primary transport. This Jarvis fork uses Telegram
# instead, but the Sendblue code is kept dormant for upstream-merge compatibility.
# Uncomment + fill these only if you want to re-enable iMessage delivery.
#
# SENDBLUE_API_KEY=
# SENDBLUE_API_SECRET=
# SENDBLUE_FROM_NUMBER=
# SENDBLUE_AUTO_WEBHOOK=true
