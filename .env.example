# ---- Telegram (primary transport for this fork) ----
# 1. Create a bot: @BotFather → /newbot → paste the token below.
# 2. Send any message to your bot, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Find "chat":{"id":<NUMBER>} — that's your chat id.
# 3. Run `npm run dev`. No tunnel or ngrok needed — bot uses long polling.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids. Without this, anyone can message the bot.
TELEGRAM_ALLOWED_CHAT_IDS=

# ---- OpenAI (Whisper voice transcription) ----
# Required for voice message support. Get a key at https://platform.openai.com/api-keys.
# Also doubles as the embedding provider if you set it (see below).
OPENAI_API_KEY=

# ---- Convex ----
# Run: npx convex dev — Convex creates a project and writes these to .env.local automatically.
CONVEX_DEPLOYMENT=
CONVEX_URL=
VITE_CONVEX_URL=

# ---- Claude model ----
# Uses your Claude Code subscription automatically — no separate API key needed.
# Override with ANTHROPIC_API_KEY if you want to bypass the subscription.
BOOP_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# ---- Upgrade notifications ----
# On `npm run dev`, Boop checks your `upstream` remote for new commits and
# prints a banner with the commit count + a reminder to run `/upgrade-boop`.
# Set to `false` to silence the check entirely.
# BOOP_UPSTREAM_CHECK=true

# ---- Embeddings (optional — unlocks vector search for memory recall) ----
# Pick one. If neither is set, recall falls back to substring search.
# VOYAGE_API_KEY=
# OPENAI_API_KEY=  (already covered above for Whisper)

# ---- Server ----
PORT=3456

# Public URL for your server.
# - Leave as http://localhost:3456 if you're only using Telegram (long polling
#   needs no tunnel).
# - Set to a stable public URL only if you also need inbound webhooks
#   (e.g. dormant Sendblue path below).
PUBLIC_URL=http://localhost:3456

# Optional: ngrok RESERVED domain (paid plan). Example: "boop.ngrok.app".
# Telegram doesn't need this; only relevant if you re-enable Sendblue.
# NGROK_DOMAIN=

# ---- Composio (1000+ integrations, zero-code) ----
# Get an API key at https://app.composio.dev/developers.
# Once set, connect toolkits (Gmail, Slack, GitHub, Linear, …) from the
# Debug UI's Connections tab. Each connected toolkit becomes available to
# the agent via spawn_agent(integrations: [...]).
COMPOSIO_API_KEY=

# Optional: stable user id Composio keys connections under. Defaults to
# "boop-default". Override only if you already manage Composio sessions
# elsewhere and want Boop to reuse that user.
# COMPOSIO_USER_ID=

# ============================================================================
# DORMANT — Sendblue / iMessage transport
# ============================================================================
# Sendblue is the upstream's primary transport. This Jarvis fork uses Telegram
# instead, but the Sendblue code is kept dormant for upstream-merge compatibility.
# Uncomment + fill these only if you want to re-enable iMessage delivery.
#
# SENDBLUE_API_KEY=
# SENDBLUE_API_SECRET=
# SENDBLUE_FROM_NUMBER=
# SENDBLUE_AUTO_WEBHOOK=true
