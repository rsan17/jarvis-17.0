# ---- Convex ----
# Run: npx convex dev — Convex creates a project and writes these to .env.local automatically.
CONVEX_DEPLOYMENT=
CONVEX_URL=
VITE_CONVEX_URL=

# ---- Telegram ----
# 1. Create a bot: @BotFather → /newbot → paste the token below.
# 2. Send /start to your bot, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Find "chat":{"id":<NUMBER>} — that's your chat id.
# 3. Run `npm run dev`. No tunnel or ngrok needed — bot uses long polling.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids. Without this anyone can message the bot.
TELEGRAM_ALLOWED_CHAT_IDS=

# ---- Claude model ----
# Uses Claude Code subscription by default — no API key needed.
# Uncomment to use a separate Anthropic API key instead.
BOOP_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# ---- Embeddings (optional — enables vector search for memory recall) ----
# Pick one. Falls back to substring search if neither is set.
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# ---- Server ----
PORT=3456
PUBLIC_URL=http://localhost:3456

# ---- Composio (integrations: Gmail, Slack, GitHub, Linear, …) ----
# Get key at https://app.composio.dev/developers
# Connect toolkits from the Debug UI → Connections tab.
COMPOSIO_API_KEY=
